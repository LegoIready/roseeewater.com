{
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "rewrites": [
        {
            "source": "/:path*",
            "destination": "/api/:path*.php"
        },
        {
            "source": "/public/:path*",
            "destination": "/:path*"
        }
    ]
}
